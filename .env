#############################################
# Dell Server AI Agent - Configuration File #
#############################################

###############
# SERVER HOST #
###############
# Where the FastAPI service listens
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

#############################
# REDFISH / RACADM SETTINGS #
#############################
REDFISH_PORT=443
REDFISH_API_VERSION=1.8.0

# Timeouts
CONNECTION_TIMEOUT=30
RACADM_TIMEOUT=60
MAX_RETRIES=3

###################
# SECURITY CONFIG #
###################
# low = read-only, medium = diagnostics, high = full control
SECURITY_LEVEL=high

# Leave HTTPS disabled for local testing
REQUIRE_HTTPS=false
VERIFY_SSL=false

# Authentication (app-side, not iDRAC)
SECRET_KEY=change-this-secret-key

# Override default role passwords (strongly recommended in production!)
# AUTH_ADMIN_PASSWORD=your-strong-admin-password
# AUTH_OPERATOR_PASSWORD=your-strong-operator-password
# AUTH_VIEWER_PASSWORD=your-strong-viewer-password

JWT_EXPIRY_HOURS=24

# CORS: comma-separated allowed origins. Leave empty for dev (allows all).
# In production, set to your actual domain(s):
# CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
CORS_ORIGINS=

################
# LOG SETTINGS #
################
LOG_LEVEL=INFO
LOG_FILE=agent.log

# Optional log rotation
MAX_LOG_SIZE=10485760      # 10 MB
LOG_RETENTION_DAYS=30

#########################
# PERFORMANCE / BEHAVIOR #
#########################
MAX_CONCURRENT_OPERATIONS=5
OPERATION_TIMEOUT=300
AUTO_SAVE_LOGS=true

# Caching for fast Redfish repeated queries
CACHE_RETENTION_HOURS=24

###############
# AI SETTINGS #
###############
ENABLE_AI_RECOMMENDATIONS=true
CONFIDENCE_THRESHOLD=0.7

####################
# DEVELOPMENT FLAGS #
####################
# Should be FALSE in production
DEBUG=false
DEVELOPMENT_MODE=true

# Set to true to use simulated Redfish/RACADM data (no real server needed)
DEMO_MODE=false